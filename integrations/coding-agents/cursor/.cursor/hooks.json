        "hooks": [
          {
            "type": "command",
            "command": "nemo-flow-sidecar hook-forward cursor",
            "timeout": 30
          }
        ]
      }
    ],
    "preToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "nemo-flow-sidecar hook-forward cursor",
            "timeout": 30
          }
        ]
      }
    ],
    "beforeShellExecution": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "nemo-flow-sidecar hook-forward cursor",
            "timeout": 30
          }
        ]
      }
    ],
    "beforeMCPExecution": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "nemo-flow-sidecar hook-forward cursor",
