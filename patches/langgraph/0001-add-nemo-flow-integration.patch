index 00000000..ad15faba
--- /dev/null
+++ b/libs/langgraph/langgraph/_nemo_flow.py
@@ -0,0 +1,456 @@
+# SPDX-FileCopyrightText: Copyright (c) 2026, NVIDIA CORPORATION & AFFILIATES. All rights reserved.
+# SPDX-License-Identifier: Apache-2.0
+
+"""Optional NeMo Flow integration guard and scope helpers for LangGraph.
+
+When ``nemo_flow`` is installed and a scope stack has been initialized,
+``available()`` returns ``True`` and instrumentation hooks in patched
+LangGraph modules can safely call NeMo Flow APIs. When ``nemo_flow`` is not
+installed, ``available()`` returns ``False`` and all instrumentation is
+silently skipped -- LangGraph behaves identically to an unpatched build.
+
+This module follows the same pattern as
+``langchain_nvidia_ai_endpoints/_nemo_flow.py`` and
+``langchain_openai/chat_models/_nemo_flow.py``.
+
+Scope helpers
+-------------
+``push_graph_scope`` / ``pop_graph_scope``
+    Manage the graph-level NeMo Flow scope in ``Pregel.stream()`` / ``astream()``.
+``push_subgraph_scope`` / ``pop_subgraph_scope``
+    Manage subgraph-level scopes with ContextVar save/restore for correct
+    nesting when a graph is invoked as a subgraph within another graph.
+``push_node_scope`` / ``pop_node_scope``
+    Manage per-node NeMo Flow scopes with isolated scope stacks for parallel
+    branch safety in ``run_with_retry()`` / ``arun_with_retry()``.
+``push_graph_scope`` (optional ``graph_topology`` kwarg)
+    Store graph topology as named metadata on the graph scope.
+
+Double-wrap prevention
+----------------------
+``_langgraph_nemo_flow_active`` is a ``ContextVar[bool]`` set to ``True`` while
+the LangGraph patch is actively managing scopes. External consumers (e.g.
+``NemoFlowCallbackHandler.on_chain_start`` in the langchain patch) should
+call ``langgraph_nemo_flow_active()`` and skip their own scope push when it
+returns ``True``.
+
+Lifecycle events
+----------------
+``emit_checkpoint_save`` / ``emit_checkpoint_restore``
+    Emit checkpoint lifecycle events from ``_loop.py``.
+``emit_graph_interrupt`` / ``emit_graph_resume``
+    Emit interrupt/resume lifecycle events from ``_loop.py``.
+``emit_edge_write``
+    Emit edge traversal events from ``_write.py`` (Phase 5).
+``emit_superstep_start`` / ``emit_superstep_end``
+    Emit superstep boundary events from ``_loop.py`` (Phase 5).
+"""
+
+from __future__ import annotations
+
+import contextvars
+import logging
+from typing import Any, NamedTuple
+
+_logger = logging.getLogger(__name__)
+
+try:
+    import nemo_flow
+
+    _HAS_NEMO_FLOW = True
+except ImportError:  # pragma: no cover
+    nemo_flow = None  # type: ignore[assignment]
+    _HAS_NEMO_FLOW = False
+
+# ---------------------------------------------------------------------------
+# ContextVars for cross-module coordination
+# ---------------------------------------------------------------------------
+
+# Flag: True when the LangGraph patch is managing scopes -- tells
+# NemoFlowCallbackHandler.on_chain_start to skip its own scope push.
+_langgraph_nemo_flow_active: contextvars.ContextVar[bool] = contextvars.ContextVar(
+    "_langgraph_nemo_flow_active", default=False
+)
+
+
+class _GraphScopeInfo(NamedTuple):
+    """Carries graph identity from stream()/astream() to run_with_retry()."""
+
+    graph_name: str
+    metadata: dict
+    response_codec: object | None = None
+
+
+# Stores the graph scope identity so run_with_retry can reconstruct it
+# on a new (per-branch) scope stack.
+_graph_scope_info: contextvars.ContextVar[_GraphScopeInfo | None] = (
+    contextvars.ContextVar("_graph_scope_info", default=None)
+)
+
+
+# ---------------------------------------------------------------------------
+# Guard function (unchanged from Phase 1)
+# ---------------------------------------------------------------------------
+
+
+def available() -> bool:
+    """Return True when nemo_flow is importable *and* a scope stack is active.
+
+    This two-part check ensures instrumentation only fires when the caller
+    has explicitly created a NeMo Flow scope stack. A bare ``import nemo_flow``
+    is not sufficient -- the scope stack must be active.
+    """
+    if not _HAS_NEMO_FLOW:
+        return False
+    try:
+        return nemo_flow.scope_stack_active()
+    except Exception:
+        return False
+
+
+def langgraph_nemo_flow_active() -> bool:
+    """Return True when LangGraph patch is actively managing scopes.
+
+    External consumers (e.g. ``NemoFlowCallbackHandler``) should call this
+    and skip their own scope push/pop when it returns ``True`` to avoid
+    double-wrapping.
+    """
+    return _langgraph_nemo_flow_active.get(False)
+
+
+def get_graph_response_codec() -> object | None:
+    """Return the response codec from the current graph scope, if any.
+
+    Provider patches (langchain-openai, langchain-nvidia) can call this
+    to use a graph-level codec override instead of their hardcoded default.
+    Returns None if no graph scope is active or no response_codec was set.
+    """
+    info = _graph_scope_info.get(None)
+    if info is not None:
+        return info.response_codec
+    return None
+
+
+# ---------------------------------------------------------------------------
+# Graph-level scope helpers (used by pregel/main.py)
+# ---------------------------------------------------------------------------
+
+
+def push_graph_scope(
+    graph_name: str,
+    *,
+    response_codec: object | None = None,
+    graph_topology: dict | None = None,
+) -> Any:
+    """Push a graph-level NeMo Flow scope and set coordination ContextVars.
+
+    Must only be called after ``available()`` returns ``True``.
+
+    Args:
+        graph_name: Human-readable name for the graph scope.
+        response_codec: Optional response codec object to set as scope-default.
+            When provided, provider patches in this scope will use the
+            codec for response decoding instead of their hardcoded default.
+        graph_topology: Optional graph topology dict (nodes, edges) stored
+            as named metadata on the scope under ``"graph_topology"``.
+
+    Returns the ``ScopeHandle`` for the graph scope.
+    """
+    metadata: dict[str, Any] = {"langgraph.graph": True}
+    if graph_topology is not None:
+        metadata["graph_topology"] = graph_topology
+    handle = nemo_flow.scope.push(
+        graph_name,
+        nemo_flow.ScopeType.Agent,
+        metadata=metadata,
+    )
+    _langgraph_nemo_flow_active.set(True)
+    _graph_scope_info.set(
+        _GraphScopeInfo(graph_name=graph_name, metadata=metadata, response_codec=response_codec)
+    )
+    return handle
+
+
+def pop_graph_scope(handle: Any) -> None:
+    """Pop a graph-level NeMo Flow scope and reset coordination ContextVars.
+
+    Must only be called after ``available()`` returns ``True``.
+    """
+    nemo_flow.scope.pop(handle)
+    _langgraph_nemo_flow_active.set(False)
+    _graph_scope_info.set(None)
+
+
+# ---------------------------------------------------------------------------
+# Node-level scope helpers (used by pregel/_retry.py)
+# ---------------------------------------------------------------------------
+
+
+def push_node_scope(
+    task_name: str, task_id: str
+) -> tuple[Any, Any | None, Any | None]:
+    """Push a node-level NeMo Flow scope on an isolated per-branch scope stack.
+
+    Creates a new scope stack for this parallel branch, sets it in the
+    Python ContextVar (so ``_ensure_scope_stack`` re-syncs it to the Rust
+    thread-local after every await), pushes a graph scope mirror, then
+    pushes the node scope.
+
+    Must only be called after ``available()`` returns ``True``.
+
+    Returns ``(node_handle, graph_handle, saved_stack)`` where
+    ``saved_stack`` is the ContextVar Token for restoring the parent stack.
+    """
+    # Create a fresh scope stack for this parallel branch and install it
+    # in the ContextVar.  The Token lets us restore the parent on pop.
+    branch_stack = nemo_flow.create_scope_stack()
+    saved_token = nemo_flow._scope_stack_var.set(branch_stack)
+    # Sync the new branch stack to the Rust thread-local immediately
+    nemo_flow.set_thread_scope_stack(branch_stack)
+
+    # Push the graph-level scope on the branch stack (mirrors the parent)
+    info = _graph_scope_info.get(None)
+    graph_name = info.graph_name if info else "graph"
+    graph_metadata = info.metadata if info else {"langgraph.graph": True}
+    graph_handle = nemo_flow.scope.push(
+        graph_name,
+        nemo_flow.ScopeType.Agent,
+        metadata=graph_metadata,
+    )
+
+    # Push the node scope as a child of the branch graph scope
+    node_handle = nemo_flow.scope.push(
+        task_name,
+        nemo_flow.ScopeType.Agent,
+        metadata={"langgraph.node": True, "langgraph.task_id": task_id},
+    )
+    return node_handle, graph_handle, saved_token
+
+
+def pop_node_scope(node_handle: Any, graph_handle: Any | None, saved_token: Any | None = None) -> None:
+    """Pop the node-level and branch graph scopes, then restore the parent stack.
+
+    Must only be called after ``available()`` returns ``True``.
+    """
+    nemo_flow.scope.pop(node_handle)
+    if graph_handle is not None:
+        nemo_flow.scope.pop(graph_handle)
+    if saved_token is not None:
+        nemo_flow._scope_stack_var.reset(saved_token)
+
+
+# ---------------------------------------------------------------------------
+# Subgraph-level scope helpers (used by pregel/main.py for nested graphs)
+# ---------------------------------------------------------------------------
+
+def push_subgraph_scope(
+    graph_name: str,
+    *,
+    response_codec: object | None = None,
+) -> tuple[Any, contextvars.Token, contextvars.Token]:
+    """Push a subgraph-level scope on the CURRENT scope stack.
+
+    Unlike ``push_graph_scope()`` which sets coordination ContextVars for
+    a root graph, this pushes directly on the existing stack -- making
+    it a child of whatever scope is currently active (the parent node).
+
+    Args:
+        graph_name: Human-readable name for the subgraph scope.
+        response_codec: Optional response codec object to set as scope-default.
+
+    Returns ``(handle, active_token, info_token)`` where the tokens are
+    used by ``pop_subgraph_scope`` to restore parent ContextVar values.
+    """
+    # Save previous ContextVar values for restoration after subgraph completes
+    active_token = _langgraph_nemo_flow_active.set(True)
+    info_token = _graph_scope_info.set(
+        _GraphScopeInfo(
+            graph_name=graph_name,
+            metadata={"langgraph.graph": True, "langgraph.subgraph": True},
+            response_codec=response_codec,
+        )
+    )
+    handle = nemo_flow.scope.push(
+        graph_name,
+        nemo_flow.ScopeType.Agent,
+        metadata={"langgraph.graph": True, "langgraph.subgraph": True},
+    )
+    return handle, active_token, info_token
+
+
+def pop_subgraph_scope(
+    handle: Any,
+    active_token: contextvars.Token,
+    info_token: contextvars.Token,
+) -> None:
+    """Pop a subgraph-level scope and restore parent ContextVar values.
+
+    Unlike ``pop_graph_scope()`` which unconditionally resets ContextVars,
+    this restores the previous values so the parent graph continues
+    correctly after the subgraph completes.
+    """
+    nemo_flow.scope.pop(handle)
+    _langgraph_nemo_flow_active.reset(active_token)
+    _graph_scope_info.reset(info_token)
+
+
+# ---------------------------------------------------------------------------
+# Lifecycle event helpers (used by pregel/_loop.py for Phase 4 events)
+# ---------------------------------------------------------------------------
+
+
+def emit_checkpoint_save(
+    source: str, step: int, thread_id: str | None, checkpoint_id: str
+) -> None:
+    """Emit a 'Checkpoint Save' NeMo Flow event.
+
+    Called from _put_checkpoint() when a checkpoint is actually persisted.
+    The ``source`` field distinguishes input/loop/exit checkpoints (D-02).
+    """
+    if not available():
+        return
+    nemo_flow.scope.event(
+        "Checkpoint Save",
+        data={
+            "source": source,
+            "step": step,
+            "thread_id": thread_id,
+            "checkpoint_id": checkpoint_id,
+        },
+    )
+
+
+def emit_checkpoint_restore(
+    checkpoint_id: str, thread_id: str | None, step: int
+) -> None:
+    """Emit a 'Checkpoint Restore' NeMo Flow event.
+
+    Called from __enter__/__aenter__ when a real checkpoint is loaded
+    (not on first run with empty checkpoint).
+    """
+    if not available():
+        return
+    nemo_flow.scope.event(
+        "Checkpoint Restore",
+        data={
+            "checkpoint_id": checkpoint_id,
+            "thread_id": thread_id,
+            "step": step,
+        },
+    )
+
+
+def emit_graph_interrupt(
+    trigger: str, interrupts: list,
+) -> None:
+    """Emit a 'Graph Interrupt' NeMo Flow event.
+
+    Called just before ``raise GraphInterrupt()`` in tick() or after_tick().
+    ``trigger`` is ``"before"`` or ``"after"`` (D-07).
+    ``interrupts`` contains serialized interrupt payloads (D-06).
+    """
+    if not available():
+        return
+    # Serialize interrupt payloads safely -- values can be arbitrary Python objects
+    serialized = []
+    for intr in interrupts:
+        try:
+            serialized.append({"value": str(intr.value), "id": getattr(intr, "id", None)})
+        except Exception:
+            serialized.append({"value": "<unserializable>", "id": None})
+    nemo_flow.scope.event(
+        "Graph Interrupt",
+        data={
+            "trigger": trigger,
+            "interrupts": serialized,
+        },
+    )
+
+
+def emit_graph_resume(resume_values: object) -> None:
+    """Emit a 'Graph Resume' NeMo Flow event.
+
+    Called in _first() when Command(resume=...) is detected.
+    Fires after checkpoint restoration but before node execution (D-09).
+    """
+    if not available():
+        return
+    # Serialize resume values safely
+    try:
+        serialized = str(resume_values)
+    except Exception:
+        serialized = "<unserializable>"
+    nemo_flow.scope.event(
+        "Graph Resume",
+        data={
+            "resume_values": serialized,
+        },
+    )
+
+
+# ---------------------------------------------------------------------------
+# Edge and superstep event helpers (used by pregel/_write.py and _loop.py — Phase 5)
+# ---------------------------------------------------------------------------
+
+
+def emit_edge_write(source_node: str, channels: list, write_count: int) -> None:
+    """Emit an 'Edge Write' NeMo Flow event when ChannelWrite._write/_awrite fires.
+
+    Called from _write() and _awrite() after the writes list is built and
+    before self.do_write() is called. Fires within the active node scope
+    (ChannelWrite executes inside task.proc.invoke() which is wrapped by
+    push_node_scope in run_with_retry).
+
+    Args:
+        source_node: Node name extracted from CONFIG_KEY_CHECKPOINT_NS via D-02 formula.
+        channels: List of destination channel names. ChannelWriteEntry -> w.channel,
+                  Send -> w.node, ChannelWriteTupleEntry -> "...".
+        write_count: Total number of entries in the resolved writes list.
+    """
+    if not available():
+        return
+    nemo_flow.scope.event(
+        "Edge Write",
+        data={
+            "source_node": source_node,
+            "channels": channels,
+            "write_count": write_count,
+        },
+    )
+
+
+def emit_superstep_start(step: int, task_count: int) -> None:
+    """Emit a 'Superstep Start' NeMo Flow event at the beginning of a Pregel superstep.
+
+    Called from tick() just before returning True (after all early returns for
+    out_of_steps, done, and interrupt_before). At this point self.tasks is populated
+    so task_count is accurate (D-04).
+
+    Fires within the graph-level scope (D-05): superstep events are not node-scoped.
+    Subgraph loops emit their own Superstep Start/End events within their subgraph scope.
+    """
+    if not available():
+        return
+    nemo_flow.scope.event(
+        "Superstep Start",
+        data={"step": step, "task_count": task_count},
+    )
+
+
+def emit_superstep_end(step: int, task_count: int) -> None:
+    """Emit a 'Superstep End' NeMo Flow event after a Pregel superstep completes.
+
+    Called from after_tick() immediately after apply_writes() returns and before
+    _put_checkpoint() (which increments self.step). At this point all task writes
+    are collected; task_count reflects tasks that just completed (D-04).
+
+    Note: Superstep End does NOT fire when tick() returns False (out_of_steps or
+    done paths). Only completed supersteps (tasks ran and wrote) get the End bracket.
+    """
+    if not available():
+        return
+    nemo_flow.scope.event(
+        "Superstep End",
+        data={"step": step, "task_count": task_count},
+    )
+
