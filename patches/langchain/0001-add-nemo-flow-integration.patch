diff --git a/libs/core/langchain_core/callbacks/nemo_flow_handler.py b/libs/core/langchain_core/callbacks/nemo_flow_handler.py
new file mode 100644
index 0000000000..72e9614607
--- /dev/null
+++ b/libs/core/langchain_core/callbacks/nemo_flow_handler.py
@@ -0,0 +1,145 @@
+"""NeMo Flow callback handler for LangChain.
+
+Maps LangChain's ``run_id`` / ``parent_run_id`` hierarchy to NeMo Flow
+scopes.
+
+Tool-call lifecycle events are handled at the ``ToolNode`` level via
+``tools.execute``.  LLM-level events are captured at the provider level
+(OpenAI, Anthropic, …) where HTTP request details are available.
+
+All NeMo Flow errors are caught and logged at DEBUG level so they never
+propagate to LangChain users.
+"""
+
+from __future__ import annotations
+
+import logging
+from typing import TYPE_CHECKING, Any
+
+from langchain_core.callbacks.base import BaseCallbackHandler
+
+if TYPE_CHECKING:
+    from collections.abc import Sequence
+    from uuid import UUID
+
+    from langchain_core.agents import AgentAction, AgentFinish
+    from langchain_core.documents import Document
+    from langchain_core.outputs import LLMResult
+
+_logger = logging.getLogger(__name__)
+
+
+class NemoFlowCallbackHandler(BaseCallbackHandler):
+    """LangChain callback handler that bridges to the NeMo Flow runtime.
+
+    Responsibilities:
+
+    * **Scope management** — ``on_chain_start`` pushes a new NeMo Flow
+      ``Agent`` scope (parented to the LangChain ``parent_run_id`` scope if
+      one exists); ``on_chain_end`` / ``on_chain_error`` pop it.
+
+    Tool lifecycle is handled by ``ToolNode`` via ``tools.execute``.
+
+    The handler keeps an internal dict that maps LangChain ``run_id``
+    (UUID) to the corresponding NeMo Flow scope handle:
+
+    * ``_scope_handles: dict[UUID, ScopeHandle]``
+
+    If NeMo Flow is not installed the handler is a silent no-op.
+
+    Example::
+
+        from langchain_core.callbacks import NemoFlowCallbackHandler
+
+        handler = NemoFlowCallbackHandler()
+        llm.invoke("Hello", config={"callbacks": [handler]})
+    """
+
+    def __init__(self) -> None:
+        super().__init__()
+        self._scope_handles: dict[UUID, Any] = {}
+        self._nnex = _try_import()
+
+    # ------------------------------------------------------------------
+    # Chain (scope) lifecycle
+    # ------------------------------------------------------------------
+
+    def on_chain_start(
+        self,
+        serialized: dict[str, Any],
+        inputs: dict[str, Any],
+        *,
+        run_id: UUID,
+        parent_run_id: UUID | None = None,
+        tags: list[str] | None = None,
+        metadata: dict[str, Any] | None = None,
+        **kwargs: Any,
+    ) -> Any:
+        """Push an NeMo Flow ``Agent`` scope for this chain run."""
+        if self._nnex is None:
+            return
+        try:
+            scope = self._nnex.scope
+            name = serialized.get("name") or serialized.get("id", ["Unknown"])[-1]
+            parent = self._scope_handles.get(parent_run_id) if parent_run_id else None
+            handle = scope.push(
+                name,
+                self._nnex.ScopeType.Agent,
+                handle=parent,
+            )
+            self._scope_handles[run_id] = handle
+        except Exception:
+            _logger.debug("NeMo Flow: on_chain_start failed", exc_info=True)
+
+    def on_chain_end(
+        self,
+        outputs: dict[str, Any],
+        *,
+        run_id: UUID,
+        parent_run_id: UUID | None = None,
+        **kwargs: Any,
+    ) -> Any:
+        """Pop the NeMo Flow scope for this chain run."""
+        self._pop_scope(run_id)
+
+    def on_chain_error(
+        self,
+        error: BaseException,
+        *,
+        run_id: UUID,
+        parent_run_id: UUID | None = None,
+        **kwargs: Any,
+    ) -> Any:
+        """Pop the NeMo Flow scope on chain error."""
+        self._pop_scope(run_id)
+
+    # ------------------------------------------------------------------
+    # Helpers
+    # ------------------------------------------------------------------
+
+    def _pop_scope(self, run_id: UUID) -> None:
+        """Pop scope for *run_id*, silently ignoring any errors."""
+        if self._nnex is None:
+            return
+        handle = self._scope_handles.pop(run_id, None)
+        if handle is None:
+            return
+        try:
+            self._nnex.scope.pop(handle)
+        except Exception:
+            _logger.debug("NeMo Flow: scope.pop failed", exc_info=True)
+
+
+# ------------------------------------------------------------------
+# Module-level helpers
+# ------------------------------------------------------------------
+
+
+def _try_import() -> Any:
+    """Attempt to import ``nemo_flow``; return the module or ``None``."""
+    try:
+        from langchain_core.utils._nemo_flow import get_nemo_flow
+
+        return get_nemo_flow()
+    except Exception:
+        return None
