index 00000000..3fb0c8df
--- /dev/null
+++ b/plugins/nemo_flow/__init__.py
@@ -0,0 +1,59 @@
+# SPDX-FileCopyrightText: Copyright (c) 2026, NVIDIA CORPORATION & AFFILIATES. All rights reserved.
+# SPDX-License-Identifier: Apache-2.0
+"""NeMo-Flow ATOF event + trajectory export bridge for Hermes.
+
+Loaded automatically by Hermes's PluginManager via the
+``hermes_agent.plugins`` entry-point group when ``hermes-agent[nemo-flow]``
+is installed. Gracefully no-ops when the ``nemo-flow`` package itself is
+not importable so unpatched-Hermes installs still start cleanly.
+"""
+from __future__ import annotations
+
+import logging
+
+logger = logging.getLogger(__name__)
+
+try:
+    import nemo_flow  # noqa: F401
+
+    _NEMO_FLOW_OK = True
+except ImportError as exc:  # noqa: BLE001 — see Threat T-1008-S4
+    # SMB-05 + Threat T-1008-S4: only swallow ImportError for nemo_flow itself.
+    # Any other ImportError (transitive dep failure, syntax error in a different
+    # module, etc.) must surface so real breakage is not silently masked.
+    if getattr(exc, "name", None) not in ("nemo_flow", None):
+        raise
+    _NEMO_FLOW_OK = False
+    logger.info("nemo-flow package not installed; plugin loaded as no-op")
+
+
+def register(ctx) -> None:
+    """Plugin entry point — register lifecycle hooks.
+
+    Called by hermes_cli/plugins.py:_load_plugin() once at discovery time.
+    SMB-05 contract: this function MUST complete without raising even when
+    ``nemo-flow`` is absent, so ``LoadedPlugin.error`` stays None.
+    """
+    if not _NEMO_FLOW_OK:
+        return  # soft-import fallback: nothing to wire
+    from plugins.nemo_flow.observability import (
+        ensure_openinference_subscriber_registered,
+        on_session_end,
+        on_session_finalize,
+        on_session_reset,
+        on_session_start,
+        post_api_request,
+        post_tool_call,
+        pre_api_request,
+        pre_tool_call,
+    )
+    ensure_openinference_subscriber_registered()
+    ctx.register_hook("on_session_start", on_session_start)
+    ctx.register_hook("on_session_end", on_session_end)
+    ctx.register_hook("on_session_finalize", on_session_finalize)
+    ctx.register_hook("on_session_reset", on_session_reset)
+    ctx.register_hook("pre_api_request", pre_api_request)
+    ctx.register_hook("post_api_request", post_api_request)
+    ctx.register_hook("pre_tool_call", pre_tool_call)
+    ctx.register_hook("post_tool_call", post_tool_call)
+    logger.info("NeMo-Flow observability hooks registered (8/8)")
diff --git a/plugins/nemo_flow/config.py b/plugins/nemo_flow/config.py
new file mode 100644
index 00000000..24c1c975
--- /dev/null
+++ b/plugins/nemo_flow/config.py
@@ -0,0 +1,141 @@
+# SPDX-FileCopyrightText: Copyright (c) 2026, NVIDIA CORPORATION & AFFILIATES. All rights reserved.
+# SPDX-License-Identifier: Apache-2.0
+"""Configuration reader for the NeMo-Flow plugin.
+
+Reads from two sources, in precedence order:
+  1. HERMES_NEMO_FLOW_* environment variables (highest priority)
+  2. ~/.hermes/config.yaml nemo_flow.* block (fallback)
+Default: disabled. SMB-03 opt-in contract.
+"""
+from __future__ import annotations
+
+import os
+from pathlib import Path
+
+
+def _load_nemo_flow_block() -> dict:
+    try:
+        from hermes_cli.config import load_config
+
+        block = load_config().get("nemo_flow", {})
+        return dict(block) if isinstance(block, dict) else {}
+    except Exception:
+        return {}
+
+
+def is_enabled() -> bool:
+    """Opt-in gate: HERMES_NEMO_FLOW_ENABLED env var OR yaml nemo_flow.enabled.
+
+    Default False per locked decision (1008-RESEARCH.md user_constraints).
+    """
+    env = os.environ.get("HERMES_NEMO_FLOW_ENABLED", "").strip().lower()
+    if env in ("1", "true", "yes", "on"):
+        return True
+    if env in ("0", "false", "no", "off"):
+        return False
+    return bool(_load_nemo_flow_block().get("enabled", False))
+
+
+def atif_output_dir() -> Path:
+    """Resolve ATIF JSON output directory.
+
+    Precedence:
+      1. HERMES_NEMO_FLOW_ATIF_DIR env var
+      2. config.yaml nemo_flow.atif_output_dir
+      3. ${HERMES_HOME}/atif
+    Threat T-1008-S3: sanitize path, refuse directories outside HERMES_HOME ancestors.
+    """
+    override = os.environ.get("HERMES_NEMO_FLOW_ATIF_DIR")
+    if override:
+        resolved = Path(override).expanduser().resolve()
+        # Path-traversal guard: reject paths with suspicious parents
+        # (absolute paths are allowed as long as they resolve cleanly).
+        if ".." in Path(override).parts:
+            raise ValueError(
+                "HERMES_NEMO_FLOW_ATIF_DIR must not contain '..' path components"
+            )
+        return resolved
+    yaml_dir = _load_nemo_flow_block().get("atif_output_dir")
+    if yaml_dir:
+        return Path(yaml_dir).expanduser().resolve()
+    try:
+        from hermes_constants import get_hermes_home
+
+        return get_hermes_home() / "atif"
+    except Exception:
+        return Path.home() / ".hermes" / "atif"
+
+
+def acg_enabled() -> bool:
+    """ACG-specific sub-toggle. Default: True WHEN nemo_flow is enabled.
+
+    Precedence: HERMES_NEMO_FLOW_ACG_ENABLED env > yaml nemo_flow.acg.enabled > True.
+
+    Master-gate contract (ACG-01): if is_enabled() is False, returns False
+    regardless of the ACG-specific env or yaml values. If is_enabled() is
+    True, the ACG sub-gate defaults to True (the operator opted into the
+    integration — default the sub-gates to "on" unless they explicitly
+    disable).
+    """
+    if not is_enabled():  # master switch must be on
+        return False
+    env = os.environ.get("HERMES_NEMO_FLOW_ACG_ENABLED", "").strip().lower()
+    if env in ("1", "true", "yes", "on"):
+        return True
+    if env in ("0", "false", "no", "off"):
+        return False
+    block = _load_nemo_flow_block().get("acg", {})
+    if isinstance(block, dict):
+        # Default True — if ACG subsystem is present, assume user wants it on.
+        return bool(block.get("enabled", True))
+    return True
+
+
+def acg_config() -> dict:
+    """Return the ACG-specific config dict from yaml (or empty-dict default).
+
+    Callers (override._ensure_acg_initialized) use cfg.get(..., default) so
+    the empty-dict fallback works cleanly on any failure path. Threat
+    T-1009-S1 (credential leak): this function DOES NOT log the returned
+    dict; only override._ensure_acg_initialized logs exception TYPES + short
+    messages, never the config body (which may carry Redis passwords).
+    """
+    block = _load_nemo_flow_block().get("acg", {})
+    return dict(block) if isinstance(block, dict) else {}
+
+
+def openinference_enabled() -> bool:
+    """OpenInference export toggle. Default: off unless explicitly enabled."""
+    if not is_enabled():
+        return False
+    env = os.environ.get("HERMES_NEMO_FLOW_OPENINFERENCE_ENABLED", "").strip().lower()
+    if env in ("1", "true", "yes", "on"):
+        return True
+    if env in ("0", "false", "no", "off"):
+        return False
+
+    block = _load_nemo_flow_block().get("openinference", {})
+    if isinstance(block, dict):
+        return bool(block.get("enabled", False))
+    return False
+
+
+def openinference_config() -> dict:
+    """Return OpenInference exporter config with env overrides applied."""
+    block = _load_nemo_flow_block().get("openinference", {})
+    config = dict(block) if isinstance(block, dict) else {}
+
+    env_overrides = {
+        "transport": os.environ.get("HERMES_NEMO_FLOW_OPENINFERENCE_TRANSPORT"),
+        "endpoint": os.environ.get("HERMES_NEMO_FLOW_OPENINFERENCE_ENDPOINT"),
+        "service_name": os.environ.get("HERMES_NEMO_FLOW_OPENINFERENCE_SERVICE_NAME"),
+        "service_namespace": os.environ.get("HERMES_NEMO_FLOW_OPENINFERENCE_SERVICE_NAMESPACE"),
+        "service_version": os.environ.get("HERMES_NEMO_FLOW_OPENINFERENCE_SERVICE_VERSION"),
+        "instrumentation_scope": os.environ.get("HERMES_NEMO_FLOW_OPENINFERENCE_INSTRUMENTATION_SCOPE"),
+        "timeout_millis": os.environ.get("HERMES_NEMO_FLOW_OPENINFERENCE_TIMEOUT_MILLIS"),
+    }
+    for key, value in env_overrides.items():
+        if value not in (None, ""):
+            config[key] = value
+
+    return config
diff --git a/plugins/nemo_flow/observability.py b/plugins/nemo_flow/observability.py
new file mode 100644
index 00000000..909c489e
--- /dev/null
+++ b/plugins/nemo_flow/observability.py
@@ -0,0 +1,712 @@
+# SPDX-FileCopyrightText: Copyright (c) 2026, NVIDIA CORPORATION & AFFILIATES. All rights reserved.
+# SPDX-License-Identifier: Apache-2.0
+"""Observability bridge for the NeMo-Flow Hermes plugin.
+
+Translates Hermes's live plugin-hook fires into a NeMo-Flow session scope,
+manual LLM/tool lifecycle spans, and AtifExporter lifecycle calls. Python
+analog of OpenClaw v1.1 ``patches/openclaw/0001-*.patch:1681-1822``
+(``ensureSessionRootScope`` + ``endNemoFlowSession``).
+
+Hook asymmetry (Pitfall P-02):
+  * ``on_session_start`` — fires ONCE per brand-new session (run_agent.py:8426-8432).
+  * ``on_session_end``   — fires at EVERY ``run_conversation`` end (per-turn).
+  * ``on_session_finalize`` — real session boundary (cli.py:642, 4119).
+  * ``on_session_reset`` — real session boundary on ``/new`` (cli.py:4167).
+
+Push on start; pop on finalize/reset. ``on_session_end`` is a documented no-op.
+"""
+
+from __future__ import annotations
+
+import atexit
+import json
+import logging
+from typing import Any
+
+logger = logging.getLogger(__name__)
+
+try:
+    import nemo_flow
+    from nemo_flow import AtifExporter, ScopeHandle, ScopeType
+
+    _NEMO_FLOW_OK = True
+except ImportError as exc:
+    if getattr(exc, "name", None) not in ("nemo_flow", None):
+        raise
+    _NEMO_FLOW_OK = False
+    AtifExporter = None  # type: ignore[assignment]
+    ScopeHandle = None  # type: ignore[assignment]
+    ScopeType = None  # type: ignore[assignment]
+
+# Module-level state (thread-safe under Hermes's single-AIAgent-per-process
+# model; batch_runner.py uses multiprocessing.Pool so each worker has its own
+# interpreter + module state per Pitfall P-05).
+_session_state: "dict[str, tuple[Any, Any, str]]" = {}
+_active_llm_calls: "dict[tuple[str, int], Any]" = {}
+_active_tool_calls: "dict[tuple[str, str], Any]" = {}
+_OPENINFERENCE_SUBSCRIBER_NAME = "nemo-flow-openinference"
+_openinference_subscriber: Any | None = None
+_openinference_cleanup_registered = False
+
+
+# ---- Version lookup (Pitfall P-07: absence-of-log is a signal) ---------
+
+
+def _hermes_version() -> str:
+    """Return the installed hermes-agent version, or the pinned fallback."""
+    try:
+        import importlib.metadata as _im
+
+        return _im.version("hermes-agent")
+    except Exception:
+        return "0.10.0"
+
+
+def _coerce_string_map(value: Any, field_name: str) -> dict[str, str]:
+    if value is None:
+        return {}
+    if not isinstance(value, dict):
+        raise TypeError(f"{field_name} must be a mapping of string keys and values")
+    return {str(key): str(item) for key, item in value.items()}
+
+
+def _llm_call_key(session_id: str, api_call_count: int) -> tuple[str, int]:
+    return session_id, api_call_count
+
+
+def _tool_call_key(session_id: str, tool_call_id: str, task_id: str, tool_name: str) -> tuple[str, str]:
+    key = tool_call_id or f"{task_id}:{tool_name}"
+    return session_id, key
+
+
+def _to_json_safe(value: Any) -> Any:
+    """Coerce SDK / pydantic / dataclass objects into JSON-serializable values.
+
+    Hermes hands ``messages``/``system``/``tools`` straight off ``api_kwargs``
+    (plain dicts/strings/lists), but ``assistant_message.tool_calls`` is often
+    an OpenAI/Anthropic SDK pydantic object. ``LLMRequest`` content and
+    ``call_end`` payloads must be JSON-compatible, so normalize defensively.
+    """
+    if value is None or isinstance(value, (bool, int, float, str)):
+        return value
+    if isinstance(value, dict):
+        return {str(k): _to_json_safe(v) for k, v in value.items()}
+    if isinstance(value, (list, tuple)):
+        return [_to_json_safe(item) for item in value]
+    for attr in ("model_dump", "dict", "to_dict"):
+        method = getattr(value, attr, None)
+        if callable(method):
+            try:
+                return _to_json_safe(method())
+            except Exception:
+                pass
+    if hasattr(value, "__dict__"):
+        try:
+            return _to_json_safe(vars(value))
+        except Exception:
+            pass
+    return str(value)
+
+
+def _build_llm_request(
+    *,
+    model: str,
+    provider: str,
+    base_url: str,
+    api_mode: str,
+    message_count: int,
+    tool_count: int,
+    approx_input_tokens: int,
+    request_char_count: int,
+    max_tokens: int,
+    messages: Any = None,
+    system: Any = None,
+    tools: Any = None,
+) -> Any:
+    safe_messages = _to_json_safe(messages) if messages is not None else []
+    if not isinstance(safe_messages, list):
+        safe_messages = [safe_messages]
+    content: dict[str, Any] = {
+        "model": model,
+        "provider": provider,
+        "base_url": base_url,
+        "api_mode": api_mode,
+        "message_count": message_count,
+        "tool_count": tool_count,
+        "approx_input_tokens": approx_input_tokens,
+        "request_char_count": request_char_count,
+        "max_tokens": max_tokens,
+        "messages": safe_messages,
+    }
+    if system is not None:
+        content["system"] = _to_json_safe(system)
+    if tools is not None:
+        content["tools"] = _to_json_safe(tools)
+    return nemo_flow.LLMRequest({}, content)
+
+
+def _build_llm_response(
+    *,
+    finish_reason: str,
+    assistant_content_chars: int,
+    assistant_tool_call_count: int,
+    response_model: str | None,
+    usage: dict | None,
+    assistant_content: Any = None,
+    assistant_tool_calls: Any = None,
+) -> dict[str, Any]:
+    response: dict[str, Any] = {
+        "role": "assistant",
+        "content": _to_json_safe(assistant_content) if assistant_content is not None else "",
+        "model": response_model,
+        "usage": usage or {},
+        "finish_reason": finish_reason,
+        "assistant_tool_call_count": assistant_tool_call_count,
+    }
+    if assistant_tool_calls:
+        response["tool_calls"] = _to_json_safe(assistant_tool_calls)
+    return response
+
+
+def _normalize_tool_result(result: Any) -> Any:
+    if isinstance(result, str):
+        try:
+            return json.loads(result)
+        except Exception:
+            return result
+    return result
+
+
+def _close_active_session_children(session_id: str, reason: str) -> None:
+    llm_keys = [key for key in _active_llm_calls if key[0] == session_id]
+    for key in llm_keys:
+        handle = _active_llm_calls.pop(key)
+        try:
+            nemo_flow.llm.call_end(
+                handle,
+                {
+                    "role": "assistant",
+                    "content": f"session_{reason}_before_llm_completion",
+                },
+                data={"hook": f"session_{reason}", "api_call_count": key[1]},
+                metadata={"source": "plugins.nemo_flow.observability"},
+            )
+        except Exception as exc:
+            logger.warning("llm.call_end cleanup failed for %s/%s: %s", session_id, key[1], exc)
+
+    tool_keys = [key for key in _active_tool_calls if key[0] == session_id]
+    for key in tool_keys:
+        handle = _active_tool_calls.pop(key)
+        try:
+            nemo_flow.tools.call_end(
+                handle,
+                {"status": f"session_{reason}_before_tool_completion"},
+                data={"hook": f"session_{reason}", "tool_call_key": key[1]},
+                metadata={"source": "plugins.nemo_flow.observability"},
+            )
+        except Exception as exc:
+            logger.warning("tool.call_end cleanup failed for %s/%s: %s", session_id, key[1], exc)
+
+
+def _shutdown_openinference_subscriber() -> None:
+    global _openinference_subscriber
+
+    subscriber = _openinference_subscriber
+    _openinference_subscriber = None
+    if subscriber is None:
+        return
+    try:
+        subscriber.force_flush()
+    except Exception as exc:
+        logger.warning("OpenInference force_flush failed during shutdown: %s", exc)
+    try:
+        subscriber.deregister(_OPENINFERENCE_SUBSCRIBER_NAME)
+    except Exception as exc:
+        logger.warning("OpenInference deregister failed during shutdown: %s", exc)
+    try:
+        subscriber.shutdown()
+    except Exception as exc:
+        logger.warning("OpenInference shutdown failed: %s", exc)
+
+
+def _force_flush_openinference_subscriber() -> None:
+    if _openinference_subscriber is None:
+        return
+    try:
+        _openinference_subscriber.force_flush()
+    except Exception as exc:
+        logger.warning("OpenInference force_flush failed: %s", exc)
+
+
+def ensure_openinference_subscriber_registered() -> None:
+    global _openinference_subscriber, _openinference_cleanup_registered
+
+    from plugins.nemo_flow.config import openinference_config, openinference_enabled
+
+    if not _NEMO_FLOW_OK or not openinference_enabled():
+        return
+    if _openinference_subscriber is not None:
+        return
+
+    raw_config = openinference_config()
+    try:
+        config = nemo_flow.OpenInferenceConfig()
+        config.transport = str(raw_config.get("transport", config.transport))
+        config.service_name = str(raw_config.get("service_name", "hermes-agent"))
+        config.instrumentation_scope = str(
+            raw_config.get(
+                "instrumentation_scope",
+                "hermes-agent/nemo-flow/openinference",
+            )
+        )
+
+        endpoint = raw_config.get("endpoint")
+        if endpoint not in (None, ""):
+            config.endpoint = str(endpoint)
+
+        service_namespace = raw_config.get("service_namespace")
+        if service_namespace not in (None, ""):
+            config.service_namespace = str(service_namespace)
+
+        service_version = raw_config.get("service_version")
+        if service_version not in (None, ""):
+            config.service_version = str(service_version)
+
+        timeout_millis = raw_config.get("timeout_millis")
+        if timeout_millis not in (None, ""):
+            config.timeout_millis = int(timeout_millis)
+
+        headers = _coerce_string_map(raw_config.get("headers"), "openinference.headers")
+        if headers:
+            config.headers = headers
+
+        resource_attributes = _coerce_string_map(
+            raw_config.get("resource_attributes"),
+            "openinference.resource_attributes",
+        )
+        if resource_attributes:
+            config.resource_attributes = resource_attributes
+
+        subscriber = nemo_flow.OpenInferenceSubscriber(config)
+        subscriber.register(_OPENINFERENCE_SUBSCRIBER_NAME)
+    except Exception as exc:
+        logger.warning("OpenInference subscriber setup failed: %s", exc)
+        return
+
+    _openinference_subscriber = subscriber
+    if not _openinference_cleanup_registered:
+        atexit.register(_shutdown_openinference_subscriber)
+        _openinference_cleanup_registered = True
+    logger.info(
+        "OpenInference export registered (transport=%s, endpoint=%s)",
+        config.transport,
+        config.endpoint,
+    )
+
+
+# ---- Session-scope lifecycle -------------------------------------------
+
+
+def ensure_session_scope(session_id: str, model: str, platform: str) -> None:
+    """Push the NeMo-Flow scope + register AtifExporter for a session.
+
+    Idempotent — subsequent calls for the same session_id are no-ops. Called
+    by ``on_session_start`` and (Pitfall P-03) by Plan 03's first-pre-api-request
+    lazy hook for gateway continuation sessions that skip ``on_session_start``.
+    """
+    from plugins.nemo_flow.config import is_enabled
+
+    if not _NEMO_FLOW_OK or not is_enabled():
+        return
+    if session_id in _session_state:
+        return
+    try:
+        handle = nemo_flow.scope.push(
+            name=f"hermes-session-{session_id}",
+            scope_type=ScopeType.Agent,
+            data={"session_id": session_id, "model": model, "platform": platform},
+            metadata={"source": "plugins.nemo_flow.observability"},
+        )
+        exporter = AtifExporter(
+            session_id=session_id,
+            agent_name="hermes-agent",
+            agent_version=_hermes_version(),
+            model_name=model,
+        )
+        exporter_name = f"nemo-flow-atif-{session_id}"
+        exporter.register(exporter_name)
+        _session_state[session_id] = (handle, exporter, exporter_name)
+        logger.info(
+            "NeMo-Flow session scope pushed: %s (model=%s, platform=%s)",
+            session_id,
+            model,
+            platform,
+        )
+    except Exception as exc:
+        logger.warning("ensure_session_scope failed for %s: %s", session_id, exc)
+
+
+def on_session_start(session_id: str, model: str, platform: str = "", **_: Any) -> None:
+    """Hermes fires this once per brand-new session (run_agent.py:8426-8432)."""
+    ensure_session_scope(session_id, model, platform)
+
+
+def on_session_end(
+    session_id: str = "",
+    completed: bool = False,
+    interrupted: bool = False,
+    **_: Any,
+) -> None:
+    """PER-TURN hook (run_agent.py:11360) — intentional no-op for scope/export lifecycle.
+
+    Pitfall P-02: pushing/popping here produces 1-push/N-pops on multi-turn
+    sessions. The real session boundary is ``on_session_finalize`` /
+    ``on_session_reset``.
+    """
+    return
+
+
+def _finalize(session_id: str, reason: str) -> None:
+    from plugins.nemo_flow.config import atif_output_dir
+
+    state = _session_state.pop(session_id, None)
+    # Phase 1009: drop all ACG override ledger entries for this session.
+    # Threat T-1009-I1 (memory leak across sessions). Soft-imported so
+    # observability still works if override.py is absent (partial install).
+    try:
+        from plugins.nemo_flow.override import cleanup_session as _acg_cleanup
+
+        _acg_cleanup(session_id)
+    except ImportError:
+        pass
+    if state is None:
+        return
+    handle, exporter, exporter_name = state
+    _close_active_session_children(session_id, reason)
+    try:
+        nemo_flow.scope.pop(handle)
+    except Exception as exc:
+        logger.warning("scope.pop failed for %s: %s", session_id, exc)
+    _force_flush_openinference_subscriber()
+    try:
+        out_dir = atif_output_dir()
+        out_dir.mkdir(parents=True, exist_ok=True)
+        out_path = out_dir / f"{session_id}.json"
+        out_path.write_text(exporter.export_json(), encoding="utf-8")
+        logger.info("NeMo-Flow ATIF exported (%s): %s", reason, out_path)
+    except Exception as exc:
+        logger.warning("ATIF export failed for %s: %s", session_id, exc)
+    try:
+        exporter.deregister(exporter_name)
+        exporter.clear()
+    except Exception:
+        pass
+
+
+def on_session_finalize(session_id: str | None = None, platform: str = "cli", **_: Any) -> None:
+    """Hermes fires this on CLI exit (cli.py:642) and /new (cli.py:4119)."""
+    if _NEMO_FLOW_OK and session_id:
+        _finalize(session_id, reason="finalize")
+
+
+def on_session_reset(session_id: str | None = None, platform: str = "cli", **_: Any) -> None:
+    """Hermes fires this on /reset (cli.py:4167)."""
+    if _NEMO_FLOW_OK and session_id:
+        _finalize(session_id, reason="reset")
+
+
+# ---- Per-API-request hooks (OBS-03, OBS-04, OBS-05) --------------------
+
+
+def pre_api_request(
+    task_id: str = "",
+    session_id: str = "",
+    platform: str = "",
+    model: str = "",
+    provider: str = "",
+    base_url: str = "",
+    api_mode: str = "",
+    api_call_count: int = 0,
+    message_count: int = 0,
+    tool_count: int = 0,
+    approx_input_tokens: int = 0,
+    request_char_count: int = 0,
+    max_tokens: int = 0,
+    messages: Any = None,
+    system: Any = None,
+    tools: Any = None,
+    **_: Any,
+) -> None:
+    """Hermes fires this BEFORE every API attempt, including retries (run_agent.py:8889).
+
+    Dedup on ``(session_id, api_call_count)`` per Pitfall P-04: the retry
+    loop at ``run_agent.py:8832`` re-enters this hook for each retry with
+    the SAME ``api_call_count``. ``api_call_count`` is a turn-local counter
+    that increments once per outer-loop iteration (``run_agent.py:8611``).
+
+    Lazy scope-push (Pitfall P-03): gateway continuation sessions do not
+    fire ``on_session_start`` — if this is the first time we see the
+    session, push the scope and register the exporter now.
+    """
+    from plugins.nemo_flow.config import is_enabled
+
+    if not _NEMO_FLOW_OK or not is_enabled():
+        return
+    # Pitfall P-03: lazy-push for continuation sessions that skipped on_session_start.
+    if session_id and session_id not in _session_state:
+        ensure_session_scope(session_id, model, platform)
+    if not session_id or session_id not in _session_state:
+        return  # ensure_session_scope failed or was disabled — silent no-op
+    handle, _, _ = _session_state[session_id]
+    llm_key = _llm_call_key(session_id, api_call_count)
+    # Pitfall P-04: retries re-enter pre_api_request with the same api_call_count.
+    # Keep one logical LLM span open until the matching post_api_request.
+    if llm_key in _active_llm_calls:
+        return
+
+    # Phase 1009 OBS-06: pop cache_control.owner from the override ledger.
+    # override.py's L8887 seam wrote this before the hook fired. If the
+    # seam was bypassed (ImportError, plugin absent, or override seam
+    # raised), default "none" is returned — matches the "no ACG
+    # attribution available" semantic.
+    try:
+        from plugins.nemo_flow.override import _pop_cache_control_owner
+
+        _cc_owner = _pop_cache_control_owner(session_id, api_call_count)
+    except ImportError:
+        _cc_owner = "none"
+
+    try:
+        request = _build_llm_request(
+            model=model,
+            provider=provider,
+            base_url=base_url,
+            api_mode=api_mode,
+            message_count=message_count,
+            tool_count=tool_count,
+            approx_input_tokens=approx_input_tokens,
+            request_char_count=request_char_count,
+            max_tokens=max_tokens,
+            messages=messages,
+            system=system,
+            tools=tools,
+        )
+        data = {
+            "hook": "pre_api_request",
+            "task_id": task_id,
+            "api_call_count": api_call_count,
+            "attempt_number": 1,
+            "root_uuid": getattr(handle, "uuid", None),
+            "api_mode": api_mode,
+            "provider": provider,
+            "message_count": message_count,
+            "tool_count": tool_count,
+            "approx_input_tokens": approx_input_tokens,
+            "max_tokens": max_tokens,
+            # Phase 1009 OBS-06: ACG ownership attribution span attribute.
+            # Value is one of {"acg", "native", "none"}.
+            "cache_control.owner": _cc_owner,
+        }
+        metadata = {
+            "task_id": task_id,
+            "api_call_count": api_call_count,
+            "attempt_number": 1,
+            "hook": "pre_api_request",
+            # Phase 1009 OBS-06: duplicate into metadata for generic subscribers
+            # (mark-step conversion drops metadata but other subscriber types read it).
+            "cache_control.owner": _cc_owner,
+        }
+        llm_handle = nemo_flow.llm.call(
+            provider or "llm",
+            request,
+            handle=handle,
+            data=data,
+            metadata=metadata,
+            model_name=model or None,
+        )
+        _active_llm_calls[llm_key] = llm_handle
+    except Exception as exc:
+        logger.warning("pre_api_request llm.call failed: %s", exc)
+
+
+def post_api_request(
+    task_id: str = "",
+    session_id: str = "",
+    platform: str = "",
+    model: str = "",
+    provider: str = "",
+    base_url: str = "",
+    api_mode: str = "",
+    api_call_count: int = 0,
+    api_duration: float = 0.0,
+    finish_reason: str = "",
+    message_count: int = 0,
+    response_model: str | None = None,
+    usage: dict | None = None,
+    assistant_content_chars: int = 0,
+    assistant_tool_call_count: int = 0,
+    assistant_content: Any = None,
+    assistant_tool_calls: Any = None,
+    **_: Any,
+) -> None:
+    """Hermes fires this AFTER every successful API attempt (run_agent.py:10400).
+
+    No dedup needed: retries that fail exit via the exception path and never
+    reach post_api_request — only successful attempts get here.
+    """
+    from plugins.nemo_flow.config import is_enabled
+
+    if not _NEMO_FLOW_OK or not is_enabled():
+        return
+    if not session_id or session_id not in _session_state:
+        return
+    llm_key = _llm_call_key(session_id, api_call_count)
+    llm_handle = _active_llm_calls.pop(llm_key, None)
+    if llm_handle is None:
+        return
+    try:
+        response = _build_llm_response(
+            finish_reason=finish_reason,
+            assistant_content_chars=assistant_content_chars,
+            assistant_tool_call_count=assistant_tool_call_count,
+            response_model=response_model,
+            usage=usage,
+            assistant_content=assistant_content,
+            assistant_tool_calls=assistant_tool_calls,
+        )
+        data = {
+            "hook": "post_api_request",
+            "task_id": task_id,
+            "api_call_count": api_call_count,
+            "api_mode": api_mode,
+            "response_model": response_model,
+            "api_duration_seconds": api_duration,
+            "usage": usage or {},
+            "assistant_content_chars": assistant_content_chars,
+            "assistant_tool_call_count": assistant_tool_call_count,
+        }
+        metadata = {
+            "task_id": task_id,
+            "api_call_count": api_call_count,
+            "hook": "post_api_request",
+        }
+        nemo_flow.llm.call_end(
+            llm_handle,
+            response,
+            data=data,
+            metadata=metadata,
+        )
+    except Exception as exc:
+        logger.warning("post_api_request llm.call_end failed: %s", exc)
+
+
+# ---- Per-tool-call hooks (OBS-03, OBS-04 tool branch) ------------------
+
+
+def pre_tool_call(
+    tool_name: str = "",
+    args: dict | None = None,
+    task_id: str = "",
+    session_id: str = "",
+    tool_call_id: str = "",
+    **_: Any,
+) -> dict | None:
+    """Hermes fires this before tool dispatch (run_agent.py:7338).
+
+    Returns ``None`` — this plugin is observability-only and never gates
+    tool execution. A non-None return would BLOCK the tool call.
+    """
+    from plugins.nemo_flow.config import is_enabled
+
+    if not _NEMO_FLOW_OK or not is_enabled():
+        return None
+    if not session_id or session_id not in _session_state:
+        return None
+    handle, _, _ = _session_state[session_id]
+    tool_key = _tool_call_key(session_id, tool_call_id, task_id, tool_name)
+    if tool_key in _active_tool_calls:
+        return None
+    try:
+        data = {
+            "hook": "pre_tool_call",
+            "task_id": task_id,
+            "tool_call_id": tool_call_id,
+            "tool_name": tool_name,
+        }
+        metadata = {
+            "task_id": task_id,
+            "tool_call_id": tool_call_id,
+            "hook": "pre_tool_call",
+        }
+        tool_handle = nemo_flow.tools.call(
+            tool_name,
+            args or {},
+            handle=handle,
+            data=data,
+            metadata=metadata,
+            tool_call_id=tool_call_id or None,
+        )
+        _active_tool_calls[tool_key] = tool_handle
+    except Exception as exc:
+        logger.warning("pre_tool_call tools.call failed: %s", exc)
+    return None
+
+
+def post_tool_call(
+    tool_name: str = "",
+    result: Any = None,
+    task_id: str = "",
+    session_id: str = "",
+    tool_call_id: str = "",
+    **_: Any,
+) -> None:
+    """Hermes fires this after tool dispatch."""
+    from plugins.nemo_flow.config import is_enabled
+
+    if not _NEMO_FLOW_OK or not is_enabled():
+        return
+    if not session_id or session_id not in _session_state:
+        return
+    tool_key = _tool_call_key(session_id, tool_call_id, task_id, tool_name)
+    tool_handle = _active_tool_calls.pop(tool_key, None)
+    if tool_handle is None:
+        return
+    try:
+        result_chars = len(str(result)) if result is not None else 0
+        data = {
+            "hook": "post_tool_call",
+            "task_id": task_id,
+            "tool_call_id": tool_call_id,
+            "tool_name": tool_name,
+            "result_chars": result_chars,
+        }
+        metadata = {
+            "task_id": task_id,
+            "tool_call_id": tool_call_id,
+            "hook": "post_tool_call",
+        }
+        nemo_flow.tools.call_end(
+            tool_handle,
+            _normalize_tool_result(result),
+            data=data,
+            metadata=metadata,
+        )
+    except Exception as exc:
+        logger.warning("post_tool_call tools.call_end failed: %s", exc)
+
+
+__all__ = [
+    "on_session_start",
+    "on_session_end",
+    "on_session_finalize",
+    "on_session_reset",
+    "ensure_session_scope",
+    "ensure_openinference_subscriber_registered",
+    "pre_api_request",
+    "post_api_request",
+    "pre_tool_call",
+    "post_tool_call",
+    "_session_state",
+    "_active_llm_calls",
+    "_active_tool_calls",
+]
