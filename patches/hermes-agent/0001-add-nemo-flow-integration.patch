@@ -0,0 +1,621 @@
+# SPDX-FileCopyrightText: Copyright (c) 2026, NVIDIA CORPORATION & AFFILIATES. All rights reserved.
+# SPDX-License-Identifier: Apache-2.0
+"""ACG override helper for the NeMo-Flow Hermes plugin.
+
+Phase 1009 glue: when Hermes's outbound request has ``api_mode ==
+"anthropic_messages"`` AND ACG is enabled, this helper authoritatively owns
+``cache_control`` marker placement on ``api_kwargs["messages"]`` /
+``["system"]`` / ``["tools"]``. When disabled or when ``api_mode`` is not
+Anthropic, native Hermes behavior runs untouched.
+
+Fail-open (ACG-02): any failure in config read, plugin init, or translation
+logs exactly once and falls back to the native cache-control path. The
+session is NEVER crashed by an ACG problem.
+
+Gated call-site: ``run_agent.py:8887`` (inserted in Plan 02). This module
+stands alone in Plan 01; Plan 02 writes the seam hunk and fills the
+``_translate_in_place`` body with the strip-and-rewrite codec round-trip.
+"""
+
+from __future__ import annotations
+
+import asyncio
+import copy
+import logging
+import threading
+from typing import Any, Callable, Literal
+
+logger = logging.getLogger(__name__)
+
+# Soft-import guard (same pattern as observability.py:26-37).
+try:
+    import nemo_flow  # noqa: F401
+    from nemo_flow.adaptive import (  # noqa: F401
+        AcgConfig,
+        AdaptiveConfig,
+        AdaptiveRuntime,
+        BackendSpec,
+        StateConfig,
+        TelemetryConfig,
+    )
+
+    _NEMO_FLOW_OK = True
+except ImportError as exc:  # noqa: BLE001 — see Threat T-1008-S4
+    if getattr(exc, "name", None) not in ("nemo_flow", None):
+        raise
+    _NEMO_FLOW_OK = False
+    AcgConfig = None  # type: ignore[assignment]
+    AdaptiveConfig = None  # type: ignore[assignment]
+    AdaptiveRuntime = None  # type: ignore[assignment]
+    BackendSpec = None  # type: ignore[assignment]
+    StateConfig = None  # type: ignore[assignment]
+    TelemetryConfig = None  # type: ignore[assignment]
+    logger.info("nemo-flow package not installed; ACG override disabled")
+
+
+Owner = Literal["acg", "native", "none"]
+
+# ---- Module-level ledgers ---------------------------------------------
+#
+# All four ledgers are cleaned up in observability._finalize on
+# on_session_finalize / on_session_reset (extended in Plan 03).
+#
+# Threading note (Pitfall P-05): Hermes runs AIAgent single-threaded per
+# process; batch_runner.py uses multiprocessing.Pool (each worker has its
+# own interpreter + module state). These plain dicts/sets are safe.
+
+# Per-request owner ledger. Written by maybe_apply_acg_override at the
+# L8887 seam; popped by observability.pre_api_request at emit time.
+# Key: (session_id, api_call_count).
+_pending_owner: "dict[tuple[str, int], Owner]" = {}
+
+# Per-session idempotency guard for _ensure_acg_initialized. First call
+# initializes, subsequent calls short-circuit.
+_acg_initialized: "set[str]" = set()
+
+# Per-session init-failure flag. Set ONCE per session when plugin.initialize
+# raises or returns error diagnostics; every subsequent maybe_apply_acg_override
+# call for that session falls through to owner="native" without re-trying
+# init or re-logging (ACG-02 single-log contract).
+_acg_init_failed: "set[str]" = set()
+
+# Optional ACG config cache per session (Plan 02 may read this to avoid
+# re-reading yaml on every translation call). Cleared on session finalize.
+_acg_config_cache: "dict[str, dict]" = {}
+
+# Per-session AdaptiveRuntime handles backing the live ACG HotCache.
+_acg_runtimes: "dict[str, AdaptiveRuntime]" = {}
+
+
+# ---- Public API --------------------------------------------------------
+
+
+def maybe_apply_acg_override(
+    api_kwargs: dict[str, Any],
+    *,
+    api_mode: str,
+    session_id: str,
+    api_call_count: int,
+) -> tuple[dict[str, Any], Owner]:
+    """Apply ACG cache_control override when eligible; otherwise pass through.
+
+    ACG fires only when ALL of:
+      1. ``_NEMO_FLOW_OK`` (nemo-flow package importable)
+      2. ``api_mode == "anthropic_messages"`` (per-request gate — Pitfall P-04)
+      3. ``acg_enabled()`` (config says ACG is on — master-gated by is_enabled)
+      4. ``session_id not in _acg_init_failed`` (fail-open on prior init failure)
+
+    Returns ``(api_kwargs, owner)`` where owner is:
+      - ``"acg"``:    ACG translated; cache_control markers are ACG-authored
+      - ``"native"``: ACG did not run; native apply_anthropic_cache_control
+                       output is preserved (ACG disabled, init failed, or
+                       per-request translation failed)
+      - ``"none"``:   ``api_mode != "anthropic_messages"`` — NEITHER writer
+                       owned markers on this payload (non-Anthropic-shape)
+
+    Note: the ``api_kwargs`` dict is mutated in place when owner is ``"acg"``;
+    when owner is ``"native"`` or ``"none"``, the dict is returned unchanged.
+    The tuple-return shape is stable across all three outcomes so callers
+    do not need to special-case.
+    """
+    # Per-request gate (ACG-07 fallback re-evaluation) — strict shape match.
+    # Do NOT cache api_mode at session start; _try_activate_fallback rewrites
+    # self.api_mode mid-session (run_agent.py:5976-6123).
+    if api_mode != "anthropic_messages":
+        return api_kwargs, "none"
+
+    # Soft-import fallback: if nemo-flow is absent, native runs as-is.
+    if not _NEMO_FLOW_OK:
+        return api_kwargs, "native"
+
+    # Master + ACG gate check.
+    from plugins.nemo_flow.config import acg_enabled
+
+    if not acg_enabled():
+        return api_kwargs, "native"
+
+    # Fail-open: if init failed earlier for this session, stay native.
+    # This is sticky per session — do NOT retry init mid-session.
+    if session_id in _acg_init_failed:
+        return api_kwargs, "native"
+
+    # Lazy init (Pitfall P-06: do NOT re-init on every request).
+    try:
+        _ensure_acg_initialized(session_id)
+    except Exception as exc:
+        # ACG-02: log ONCE per session, mark session failed, fall back silently.
+        # Threat T-1009-S1: log only the exception TYPE + message via %s,
+        # never the config dict body (may carry Redis connection strings
+        # with passwords).
+        logger.warning(
+            "ACG initialization failed for session %s — falling back to "
+            "native prompt caching for the remainder of the session. "
+            "Reason: %s",
+            session_id,
+            exc,
+        )
+        _acg_init_failed.add(session_id)
+        return api_kwargs, "native"
+
+    # Per-request translation.
+    try:
+        _translate_in_place(api_kwargs, session_id=session_id)
+    except Exception as exc:
+        # Per-request translation failure: fall back to native for THIS
+        # request ONLY. Do NOT poison the session (different failure class
+        # from init). Next request in this session will retry translation.
+        if not getattr(exc, "_nemo_flow_logged", False):
+            logger.warning(
+                "ACG translation failed for session %s api_call_count %d — "
+                "falling back to native for this request. Reason: %s",
+                session_id,
+                api_call_count,
+                exc,
+            )
+        return api_kwargs, "native"
+
+    return api_kwargs, "acg"
+
+
+def _record_cache_control_owner(session_id: str, api_call_count: int, owner: Owner) -> None:
+    """Record the owner decision so observability.pre_api_request can read it.
+
+    Called by the ``run_agent.py:8887`` seam immediately after
+    ``maybe_apply_acg_override`` returns. Plan 03 extends
+    ``observability.pre_api_request`` to pop this ledger and attach
+    ``cache_control.owner`` to the emitted event ``data`` dict (OBS-06).
+    """
+    _pending_owner[(session_id, api_call_count)] = owner
+
+
+def _pop_cache_control_owner(session_id: str, api_call_count: int) -> Owner:
+    """Pop and return the owner for this request; 'none' if not recorded.
+
+    Read-once contract: matches observability's retry-dedup semantics.
+    If ``pre_api_request`` fires for a ``(session_id, api_call_count)``
+    without a matching record (e.g. override seam raised and
+    ``_record_cache_control_owner`` was never called), the default ``'none'``
+    is emitted, which correctly signals "no ACG attribution available".
+    """
+    return _pending_owner.pop((session_id, api_call_count), "none")
+
+
+def _run_awaitable_sync(awaitable_factory: Callable[[], Any]) -> Any:
+    """Run an awaitable factory from Hermes's synchronous plugin hooks."""
+    async def _runner() -> Any:
+        return await awaitable_factory()
+
+    try:
+        asyncio.get_running_loop()
+    except RuntimeError:
+        loop = asyncio.new_event_loop()
+        try:
+            asyncio.set_event_loop(loop)
+            return loop.run_until_complete(_runner())
+        finally:
+            asyncio.set_event_loop(None)
+            loop.close()
+
+    result: dict[str, Any] = {}
+    error: dict[str, BaseException] = {}
+
+    def _thread_runner() -> None:
+        loop = asyncio.new_event_loop()
+        try:
+            asyncio.set_event_loop(loop)
+            result["value"] = loop.run_until_complete(_runner())
+        except BaseException as exc:  # noqa: BLE001
+            error["exc"] = exc
+        finally:
+            asyncio.set_event_loop(None)
+            loop.close()
+
+    thread = threading.Thread(
+        target=_thread_runner,
+        name="nemo-flow-acg-sync-bridge",
+        daemon=True,
+    )
+    thread.start()
+    thread.join()
+
+    if "exc" in error:
+        raise error["exc"]
+    return result.get("value")
+
+
+def _get_session_runtime(session_id: str) -> AdaptiveRuntime:
+    """Return the per-session AdaptiveRuntime or raise if it is unavailable."""
+    runtime = _acg_runtimes.get(session_id)
+    if runtime is None:
+        raise RuntimeError(f"ACG runtime is unavailable for session {session_id!r}")
+    return runtime
+
+
+def _snapshot_anthropic_payload(api_kwargs: dict[str, Any]) -> dict[str, Any]:
+    """Copy only the Anthropic translator-relevant request fields."""
+    payload: dict[str, Any] = {}
+    for key in ("messages", "system", "tools", "model"):
+        if key in api_kwargs:
+            payload[key] = copy.deepcopy(api_kwargs[key])
+    return payload
+
+
+def _ensure_acg_scope_binding(session_id: str, model: str) -> None:
+    """Ensure the session scope exists and the runtime is bound to it."""
+    from plugins.nemo_flow.observability import _session_state, ensure_session_scope
+
+    if session_id not in _session_state:
+        ensure_session_scope(session_id, model, "")
+    state = _session_state.get(session_id)
+    if state is None:
+        raise RuntimeError(f"NeMo Flow session scope is unavailable for session {session_id!r}")
+    handle, _, _ = state
+    _get_session_runtime(session_id).bind_scope(handle)
+
+
+# ---- Init lazy-loader (async sync-bridge) -----------------------------
+
+
+def _ensure_acg_initialized(session_id: str) -> None:
+    """Initialize a session-owned AdaptiveRuntime once per session. Idempotent."""
+    if session_id in _acg_initialized:
+        return
+    from plugins.nemo_flow.config import acg_config
+
+    cfg = acg_config()  # reads nemo_flow.acg.* yaml block + env overrides
+    runtime = AdaptiveRuntime(
+        AdaptiveConfig(
+            agent_id=cfg.get("agent_id", "hermes-agent"),
+            state=StateConfig(backend=BackendSpec.in_memory()),
+            telemetry=TelemetryConfig(learners=["acg"]),
+            acg=AcgConfig(
+                provider=cfg.get("provider", "anthropic"),
+                observation_window=int(cfg.get("observation_window", 100)),
+                priority=int(cfg.get("priority", 50)),
+            ),
+        ).to_dict()
+    )
+
+    _run_awaitable_sync(lambda: runtime.register())
+    _acg_runtimes[session_id] = runtime
+    _acg_config_cache[session_id] = cfg
+    _acg_initialized.add(session_id)
+
+
+# ---- Single-writer invariant helpers (ACG-06) -------------------------
+
+
+def _strip_existing_cache_control(api_kwargs: dict[str, Any]) -> None:
+    """Remove any existing cache_control markers before ACG writes its own.
+
+    Enforces the ACG-06 single-writer invariant structurally: after this
+    sweep plus the ACG translation pass, exactly one writer (ACG) owns
+    cache_control markers on the outbound payload. Pitfall P-02
+    (double-tagging) is eliminated — not merely avoided by config discipline.
+
+    Walks all four locations cache_control can legally appear on an
+    Anthropic ``messages.create`` payload:
+      1. ``messages[i]["content"][j]["cache_control"]`` — content-block form
+      2. ``messages[i]["cache_control"]`` — tool-role top-level form
+      3. ``system[j]["cache_control"]`` — structured-system form
+      4. ``tools[j]["cache_control"]`` — tool-caching form
+
+    Does NOT touch the string form of ``system`` (scalar text) since that
+    shape cannot carry cache_control anyway.
+    """
+    for msg in api_kwargs.get("messages", []) or []:
+        if not isinstance(msg, dict):
+            continue
+        content = msg.get("content")
+        if isinstance(content, list):
+            for block in content:
+                if isinstance(block, dict):
+                    block.pop("cache_control", None)
+        # Tool-role special case (top-level cache_control on the message).
+        msg.pop("cache_control", None)
+
+    sys = api_kwargs.get("system")
+    if isinstance(sys, list):
+        for block in sys:
+            if isinstance(block, dict):
+                block.pop("cache_control", None)
+
+    for tool in api_kwargs.get("tools", []) or []:
+        if isinstance(tool, dict):
+            tool.pop("cache_control", None)
+
+
+def _count_cache_markers(api_kwargs: dict[str, Any]) -> int:
+    """Count cache_control markers present on the payload.
+
+    Used by _translate_in_place as a post-condition guard (ACG-06 breakpoint
+    budget <= 4 per Anthropic's API contract). Mirrors the structure of
+    _strip_existing_cache_control exactly, so any shape the stripper clears
+    is also counted here.
+    """
+    count = 0
+    for msg in api_kwargs.get("messages", []) or []:
+        if not isinstance(msg, dict):
+            continue
+        content = msg.get("content")
+        if isinstance(content, list):
+            for block in content:
+                if isinstance(block, dict) and "cache_control" in block:
+                    count += 1
+        if "cache_control" in msg:
+            count += 1
+    sys = api_kwargs.get("system")
+    if isinstance(sys, list):
+        for block in sys:
+            if isinstance(block, dict) and "cache_control" in block:
+                count += 1
+    for tool in api_kwargs.get("tools", []) or []:
+        if isinstance(tool, dict) and "cache_control" in tool:
+            count += 1
+    return count
+
+
+# ---- Translator body (Plan 02 implementation) -------------------------
+
+
+def _observe_translation_request(payload: dict[str, Any], *, session_id: str) -> None:
+    """Feed the live session runtime one typed Anthropic request observation."""
+    if session_id not in _acg_runtimes:
+        return
+
+    from nemo_flow import LLMRequest, ScopeType, codecs, llm, scope
+
+    runtime = _get_session_runtime(session_id)
+    agent_id = _acg_config_cache.get(session_id, {}).get("agent_id", "hermes-agent")
+    request = LLMRequest({}, payload)
+
+    async def _record(_request):  # noqa: ANN202
+        _ = _request
+        return {"id": f"nemo-flow-acg-observation-{session_id}", "type": "message"}
+
+    async def _execute_observation():  # noqa: ANN202
+        with scope.scope(
+            f"{agent_id}-acg-observation",
+            ScopeType.Agent,
+            data={"session_id": session_id, "source": "plugins.nemo_flow.override"},
+            metadata={"source": "plugins.nemo_flow.override"},
+        ):
+            return await llm.execute(
+                "anthropic",
+                request,
+                _record,
+                model_name=payload.get("model"),
+                codec=codecs.AnthropicMessagesCodec(),
+            )
+
+    _run_awaitable_sync(_execute_observation)
+    runtime.wait_for_idle()
+
+
+def _translate_in_place(api_kwargs: dict[str, Any], *, session_id: str) -> None:
+    """Apply ACG cache_control markers to ``api_kwargs`` in place.
+
+    ACG-06 single-writer invariant (Threat T-1009-S2): this function
+    STRUCTURALLY enforces that exactly one writer owns cache_control by:
+      1. Stripping any existing native cache_control markers from
+         messages / system / tools (via _strip_existing_cache_control).
+      2. Running the ACG translator to decide new marker positions.
+      3. Writing those markers onto the post-sanitizer payload (this seam
+         is post-_build_api_kwargs, so thinking-block sanitizer has already
+         run per Pitfall P-03 / ACG-05).
+      4. Asserting <= 4 markers total (Anthropic's breakpoint budget).
+
+    Translation backend choice:
+      - **Option A (preferred):** nemo_flow.adaptive codec round-trip via
+        AnthropicMessagesCodec — Assumption A1 in 1009-RESEARCH.md L793.
+        If the codec exposes a callable Python entry point that accepts
+        an Anthropic-shape api_kwargs and returns an annotated request
+        with cache_control decisions, use it.
+      - **Option B (fallback):** if the codec is not directly callable from
+        Python in the current nemo-flow build, place markers on the last
+        cacheable block of the system + last 3 non-system message boundaries
+        (mirrors the native Hermes semantic at
+        agent/prompt_caching.py:41-72 but via ACG-owned placement logic).
+        Use the distinguishable shape ``{"type": "ephemeral", "ttl": "5m"}``
+        so tests can assert ACG authorship via the presence of the "ttl"
+        key (native Hermes uses plain ``{"type": "ephemeral"}`` per
+        prompt_caching.py:21).
+
+    Per-request translation failures (Option A or B raising) propagate up
+    to maybe_apply_acg_override's try/except which degrades to owner="native"
+    for THIS request only (session is NOT poisoned — see Plan 01 contract).
+    """
+    observed_payload = _snapshot_anthropic_payload(api_kwargs)
+    working_kwargs = dict(api_kwargs)
+    for key, value in observed_payload.items():
+        working_kwargs[key] = value
+
+    # Step 1: Strip existing markers so ACG is the sole writer.
+    _strip_existing_cache_control(working_kwargs)
+
+    # Step 2+3: Run ACG translator (Option A preferred, Option B fallback).
+    _apply_acg_markers(working_kwargs, session_id=session_id)
+
+    if session_id in _acg_runtimes:
+        try:
+            _observe_translation_request(observed_payload, session_id=session_id)
+        except Exception as exc:
+            logger.warning(
+                "ACG observation warm-up failed for session %s — continuing without new adaptive state. Reason: %s",
+                session_id,
+                exc,
+            )
+
+    # Step 4: Post-condition — assert <= 4 breakpoints (ACG-06).
+    # In production: WARNING log + drop excess. In test mode
+    # (HERMES_NEMO_FLOW_ACG_ASSERT=1): raise AssertionError so tests
+    # catch regressions loudly.
+    import os as _os
+
+    count = _count_cache_markers(working_kwargs)
+    if count > 4:
+        if _os.environ.get("HERMES_NEMO_FLOW_ACG_ASSERT", "").strip().lower() in ("1", "true", "yes", "on"):
+            raise AssertionError(
+                f"ACG-06 violated: {count} cache_control markers exceed Anthropic's 4-breakpoint budget"
+            )
+        logger.warning(
+            "ACG placed %d cache_control markers (exceeds Anthropic "
+            "4-breakpoint budget); outbound request may be rejected or "
+            "silently capped",
+            count,
+        )
+
+    for key in ("messages", "system", "tools"):
+        if key in working_kwargs:
+            api_kwargs[key] = working_kwargs[key]
+
+
+def _apply_acg_markers(api_kwargs: dict[str, Any], *, session_id: str) -> None:
+    """Write ACG-authored cache_control markers onto the payload.
+
+    Option A binds the per-session ``AdaptiveRuntime`` to the long-lived Hermes
+    session scope, then explicitly invokes ``nemo_flow.llm.request_intercepts``
+    on the provider-native request. That keeps Hermes on the normal NeMo Flow
+    request-intercept surface instead of exposing a runtime-owned execution
+    intercept. ImportError still falls through to the 1009 Python fallback for
+    defense-in-depth.
+    """
+    try:
+        from nemo_flow import LLMRequest, llm
+
+        _ensure_acg_scope_binding(session_id, str(api_kwargs.get("model", "")))
+        translated_request = llm.request_intercepts(
+            "anthropic_messages",
+            LLMRequest({}, copy.deepcopy(api_kwargs)),
+        )
+        for key in ("messages", "system", "tools"):
+            if key in translated_request.content:
+                api_kwargs[key] = translated_request.content[key]
+        return
+    except (TypeError, RuntimeError) as exc:
+        logger.warning(
+            "ACG scope-bound request intercept raised; falling back to native for this request. Reason: %s",
+            exc,
+        )
+        setattr(exc, "_nemo_flow_logged", True)
+        raise
+    except ImportError:
+        pass
+
+    # Option B — fallback direct placement mirroring native semantics.
+    # Places markers with the ACG-distinguishable shape {type: ephemeral, ttl: 5m}
+    # on up to 4 breakpoints: last system block + last 3 user-message boundaries.
+    _apply_acg_markers_fallback(api_kwargs)
+
+
+def _apply_acg_markers_fallback(api_kwargs: dict[str, Any]) -> None:
+    """Fallback ACG marker placement — 4 breakpoints max, ACG-distinguishable.
+
+    Called when Option A codec round-trip is unavailable. Places the
+    ACG-distinguishable marker ``{"type": "ephemeral", "ttl": "5m"}`` on:
+      - last block of ``system`` (if system is a non-empty list-of-blocks)
+      - last content block of the last 3 non-system messages
+
+    The marker shape differs from native Hermes (which writes plain
+    ``{"type": "ephemeral"}`` per prompt_caching.py:21) by the presence of
+    the ``"ttl"`` key — tests use this to assert ACG authorship.
+
+    Bounded at 4 markers total to honor Anthropic's breakpoint budget.
+    """
+    ACG_MARKER: dict[str, Any] = {"type": "ephemeral", "ttl": "5m"}
+    placed = 0
+
+    # 1. Last system block (if structured).
+    sys = api_kwargs.get("system")
+    if isinstance(sys, list) and sys and placed < 4:
+        for block in reversed(sys):
+            if isinstance(block, dict):
+                block["cache_control"] = dict(ACG_MARKER)
+                placed += 1
+                break
+
+    # 2. Last content blocks of last 3 messages (walking from end).
+    messages = api_kwargs.get("messages", []) or []
+    eligible_msgs = [m for m in messages if isinstance(m, dict)]
+    # Walk in reverse to apply to most-recent-first; stop at 4 total markers.
+    for msg in reversed(eligible_msgs):
+        if placed >= 4:
+            break
+        content = msg.get("content")
+        if isinstance(content, list):
+            # Apply to last content block only (matches native's
+            # last-of-content semantic at prompt_caching.py:64).
+            for block in reversed(content):
+                if isinstance(block, dict) and not str(
+                    block.get("type", "")
+                ).endswith("thinking"):
+                    block["cache_control"] = dict(ACG_MARKER)
+                    placed += 1
+                    break
+        elif isinstance(content, str):
+            # Native converts string-content messages to [{type: text, ...}];
+            # we do NOT perform that conversion here (it's _build_api_kwargs's
+            # job). Skip scalar content — ACG cannot mark it without reshaping.
+            continue
+
+
+def cleanup_session(session_id: str) -> None:
+    """Drop all per-session ledger entries for ``session_id``.
+
+    Called from observability._finalize (extended in Plan 03) on
+    on_session_finalize / on_session_reset. Safe to call for a session_id
+    that was never seen (all .discard / .pop(default) calls).
+    """
+    runtime = _acg_runtimes.pop(session_id, None)
+    if runtime is not None:
+        try:
+            runtime.deregister()
+        except Exception:
+            pass
+    _acg_initialized.discard(session_id)
+    _acg_init_failed.discard(session_id)
+    _acg_config_cache.pop(session_id, None)
+    # Prune any stuck _pending_owner entries keyed on this session_id.
+    for key in list(_pending_owner.keys()):
+        if key[0] == session_id:
+            _pending_owner.pop(key, None)
+
+
+__all__ = [
+    "Owner",
+    "maybe_apply_acg_override",
+    "_record_cache_control_owner",
+    "_pop_cache_control_owner",
+    "_ensure_acg_initialized",
+    "_translate_in_place",
+    "cleanup_session",
+    "_pending_owner",
+    "_acg_initialized",
+    "_acg_init_failed",
+    "_acg_config_cache",
+    "_acg_runtimes",
+    "_strip_existing_cache_control",
+    "_count_cache_markers",
+    "_apply_acg_markers",
+    "_apply_acg_markers_fallback",
+]
