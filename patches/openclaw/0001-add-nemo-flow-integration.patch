+
+function normalizeContentText(content: unknown): string | null {
+  return extractTextFromChatContent(content, {
+    joinWith: "\n",
+    normalizeText: (text) => text.trim(),
+  });
+}
+
+function normalizeMessageText(message: unknown): string | null {
+  return normalizeContentText(asRecord(message).content);
