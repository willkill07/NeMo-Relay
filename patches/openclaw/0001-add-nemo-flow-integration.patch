+    })),
+    ...(tools.length > 0
+      ? {
+          tools: tools.map((tool) => ({
+            name: toolName(tool),
+            ...(toolDescription(tool) ? { description: toolDescription(tool) } : {}),
+            parameters: toolParameters(tool),
+          })),
+        }
+      : {}),
+    ...(toolChoice !== undefined ? { toolChoice } : {}),
+  };
+}
+
+export function buildLlmSpanMetadata(params: {
+  provider: string;
+  codecName: Exclude<NemoFlowCodecName, "auto">;
+  model: ModelLike;
+  context: ContextLike;
+  options?: StreamOptionsLike;
+  providerRequest: JsonRecord;
